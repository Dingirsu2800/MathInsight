# Copy this file to .env before running Docker Compose.
# Do not commit real secrets.

WEBAPI_PORT=8080
FRONTEND_PORT=5173
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://127.0.0.1:5173

ConnectionStrings__DefaultConnection=Server=tcp:your-server.database.windows.net,1433;Initial Catalog=MathInsight;Persist Security Info=False;User ID=your-user;Password=your-password;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
Jwt__SigningKey=CHANGE_ME_DEV_SECRET_KEY_AT_LEAST_32_CHARS

Cloudinary__CloudName=your-cloud-name
Cloudinary__ApiKey=your-api-key
Cloudinary__ApiSecret=your-api-secret

MistralOcr__ApiKey=your-api-key
MistralOcr__BaseUrl=https://api.mistral.ai
MistralOcr__Model=mistral-ocr-latest

VITE_API_BASE_URL=http://localhost:8080
VITE_ENABLE_MOCK_FALLBACK=false
