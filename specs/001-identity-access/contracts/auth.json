{
  "login": {
    "url": "/api/v1/auth/login",
    "method": "POST",
    "request": {
      "username": { "type": "string", "required": true },
      "password": { "type": "string", "required": true }
    },
    "response_200": {
      "token": { "type": "string" },
      "role": { "type": "string" },
      "username": { "type": "string" }
    },
    "response_401": {
      "error": { "type": "string", "example": "Invalid username or password" }
    }
  },
  "register_student": {
    "url": "/api/v1/auth/register",
    "method": "POST",
    "request": {
      "username": { "type": "string", "required": true },
      "email": { "type": "string", "required": true },
      "password": { "type": "string", "required": true },
      "first_name": { "type": "string", "required": true },
      "last_name": { "type": "string", "required": true },
      "current_grade": { "type": "integer", "required": true, "enum": [10, 11, 12] }
    },
    "response_201": {
      "message": { "type": "string", "example": "Student account registered successfully. Please verify your email." }
    },
    "response_409": {
      "error": { "type": "string", "example": "Conflict - email or username already exists." }
    }
  }
}
