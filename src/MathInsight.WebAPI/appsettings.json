{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "DefaultConnection": "Server=localhost;Database=MathInsightDb;Trusted_Connection=True;TrustServerCertificate=True;"
    },
    "RabbitMQ": {
        "Enabled": false,
        "Host": "localhost",
        "Username": "guest",
        "Password": "guest"
    },
    "Cors": {
        "AllowedOrigins": [
            "http://localhost:5173"
        ]
    },
    "Cloudinary": {
        "CloudName": "your-cloud-name",
        "ApiKey": "your-api-key",
        "ApiSecret": "your-api-secret"
    },

    "Jwt": {
        "Issuer": "MathInsight",
        "Audience": "MathInsightClient",
        "SigningKey": "CHANGE_ME_DEV_SECRET_KEY_AT_LEAST_32_CHARS",
        "ExpirationMinutes": 60
    },
    "Redis": {
        "Enabled": false,
        "ConnectionString": "localhost:6379"
    }
}
